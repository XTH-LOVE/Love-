<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#FFF9FD"
                android:centerColor="#F0E1F8"
                android:endColor="#FADCE9" />
        </shape>
    </item>
    <item android:width="220dp" android:height="220dp" android:gravity="center">
        <shape android:shape="oval">
            <solid android:color="#A6FFFFFF" />
            <stroke android:width="1dp" android:color="#CCFFFFFF" />
        </shape>
    </item>
    <item android:width="176dp" android:height="176dp" android:gravity="center" android:drawable="@drawable/ic_couplespace_foreground" />
</layer-list>
