{
  "name": "CoupleSpace",
  "version": "1.0.0",
  "description": "Love小家情侣共同空间桌面客户端",
  "author": "缐廷华",
  "main": "desktop/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "android:sync": "npm run generate && cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "preview": "nuxt preview",
    "desktop:dev": "electron desktop/main.cjs",
    "desktop:exe": "electron-builder --win nsis",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/local-notifications": "^8.2.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@lucide/vue": "^1.24.0",
    "@supabase/supabase-js": "^2.110.2",
    "@zegocloud/zego-uikit-prebuilt": "^2.17.3",
    "leaflet": "^1.9.4",
    "nuxt": "^4.4.8",
    "three": "^0.185.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "zego-express-engine-webrtc": "^3.12.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2"
  },
  "build": {
    "appId": "com.xiantinghua.couplespace.desktop",
    "productName": "Love小家",
    "artifactName": "Love小家-${version}-Windows-${arch}.${ext}",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "desktop/**/*",
      "public/favicon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/desktop-icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Love小家",
      "installerLanguages": [
        "zh_CN"
      ],
      "language": "2052",
      "deleteAppDataOnUninstall": false
    }
  }
}
