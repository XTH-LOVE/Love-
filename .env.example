NUXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional WebRTC relay. Use comma-separated turn:/turns: URLs when needed.
NUXT_PUBLIC_TURN_URLS=turn:your-turn-host:3478,turns:your-turn-host:5349
NUXT_PUBLIC_TURN_USERNAME=your-turn-username
NUXT_PUBLIC_TURN_CREDENTIAL=your-turn-credential
NUXT_PUBLIC_ZEGO_APP_ID=1962051148
# Optional development fallback. Prefer Edge Function Token04 in production.
NUXT_PUBLIC_ZEGO_APPSIGN=
NUXT_PUBLIC_ZEGO_SERVER=wss://webliveroom-api.zego.im/ws
# Optional real map provider. Use the key and security code from AMap console.
NUXT_PUBLIC_AMAP_KEY=
NUXT_PUBLIC_AMAP_SECURITY_CODE=
